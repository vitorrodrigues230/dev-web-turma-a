     </option>\r\n        </select>\r\n      </div>\r\n      <div class=\"inputs\">\r\n        <label id=\"opcionais-titulo\"> Selecione os opcionais</label>\r\n        <label id=\"opcionais-subtitulo\"> Selecione os complementos</label>\r\n\r\n        <div \r\n          class=\"checkbox-container\"\r\n          v-for=\"complemento in listaComplementos\" \r\n          :key=\"complemento.id\"\r\n          >\r\n          <input \r\n          type=\"checkbox\" \r\n          :name=\"complemento.nome\" \r\n          :value=\"complemento\" \r\n          />\r\n          <span>{{ complemento.nome }}</span>\r\n        </div>\r\n\r\n        <label> Adicione uma bebida</label>\r\n\r\n        <div id=\"checkbox-container\">\r\n          <input type=\"checkbox\" name=\"bebida\" />\r\n          <span>Coca</span>\r\n        </div>\r\n        <div class=\"inputs\">\r\n          <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\" />\r\n        </div>\r\n      </div>\r\n    </form>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"PedidoComponent\",\r\n  props: {\r\n    burguer: null,\r\n  },\r\n  data() {\r\n    return {\r\n        listaPontoCarne : [],\r\n    };\r\n  },\r\n  methods: {\r\n    async getTipoPontos() {\r\n        const response = fetch(\"http://localhost:3000/tipos_pontos\");\r\n        const dados = await response.json();\r\n        this.listaPontoCarne = dados;\r\n    },\r\n    async getOpcionais() {\r\n      const response = fetch(\"http://localhost:3000/tipos_pontos\");\r\n      const dados = await response.json();\r\n      this.listaPontoCarne = dados;\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getTipoPontos();\r\n    this.getOpcionais();\r\n  }  \r\n};\r\n</script>\r\n<style scoped></style>"],"mappings":"AAiEA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACLC,OAAO,EAAE;EACX,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACHC,eAAc,EAAI;IACtB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MAClB,MAAMC,QAAO,GAAIC,KAAK,C