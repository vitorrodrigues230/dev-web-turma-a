{"ast":null,"code":"export default {\n  name: \"ListaPedidoComponent\",\n  data() {\n    return {\n      listaPedidosRealizados: [],\n      listaStatusPedido: []\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(`${this.$apiUrl}/pedidos`);\n      const dados = await response.json();\n      console.log(dados);\n      this.listaPedidosRealizados = dados;\n    },\n    async consultarStatusPedido() {\n      const response = await fetch(`${this.$apiUrl}/status_pedido`);\n      this.listaStatusPedido = await response.json();\n    },\n    async deletarPedido(id) {\n      const response = await fetch(`${this.$apiUrl}/pedidos/${id}`, {\n        method: \"DELETE\"\n      });\n    },\n    async atualizarStatuspedido(event, idPedido) {\n      const idStatusAtualizado = event.target.value;\n      const atualizarJson = JSON.stringify({\n        statusId: idStatusAtualizado\n      });\n      await fetch(`http://localhost/pedidos/${idPedido}`, {\n        method: \"PATCH\",\n        headers: {\n          \"Content-Type\": \"application/json\"\n        },\n        body: atualizarJson\n      });\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n    this.consultarStatusPedido();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidosRealizados","listaStatusPedido","methods","consultarPedidos","response","fetch","$apiUrl","dados","json","console","log","consultarStatusPedido","deletarPedido","id","method","atualizarStatuspedido","event","idPedido","idStatusAtualizado","target","value","atualizarJson","JSON","stringify","statusId","headers","body","mounted"],"sources":["C:\\Users\\gusta\\OneDrive\\Documentos\\GGITHUBB\\dev-web-turma-a\\Gustavo\\Projeto final\\tburguer\\src\\components\\ListaPedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div id=\"pedidos-tabela\">\r\n      <div>\r\n        <div id=\"pedidos-tabela-cabecalho\">\r\n          <div id=\"ordem-id\">#ID</div>\r\n          <div>Nome</div>\r\n          <div>Hamburguer</div>\r\n          <div>Ponto</div>\r\n          <div>Opcionais</div>\r\n          <div>Status</div>\r\n          <div id=\"div-acoes\">Ações</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div\r\n      class=\"pedidos-tabela-linha\"\r\n      v-for=\"pedido in listaPedidosRealizados\"\r\n      :key=\"pedido.id\"\r\n    >\r\n      <div id=\"ordem-numero\">{{ pedido.id }}</div>\r\n      <div>{{ pedido.nome }}</div>\r\n      <div>{{ pedido.burguer.nome }}</div>\r\n      <div>{{ pedido.ponto.descricao }}</div>\r\n      <div>\r\n        <ul>\r\n          <li v-for=\"(complemento, index) in pedido.complemento\" :key=\"index\">\r\n            {{ complemento.nome }}\r\n          </li>\r\n        </ul>\r\n        <div class=\"divider\"></div>\r\n        <ul>\r\n          <li v-for=\"(bebida, index) in pedido.bebida\" :key=\"index\">\r\n            {{ bebida.nome }}\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div>\r\n          <select name=\"status\" class=\"status\" @change=\"atualizarStatuspedido($event, pedido.id)\">\r\n          <option value=\"\">Selecione</option>\r\n          <option\r\n            v-for=\"status in listaStatusPedido\"\r\n            :key=\"status.id\"\r\n            :value=\"status.id\"\r\n            :selected=\"status.id == pedido.statusId\"\r\n          >\r\n            {{ status.descricao }}\r\n          </option>\r\n        </select>\r\n      </div>\r\n      <div id=\"div-acoes\">\r\n        <img\r\n        @click=\"deletarPedido(pedido.id)\"\r\n         src=\"/img/icone_lixeira.png\" \r\n         width=\"35px\" \r\n         height=\"35px\" />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"ListaPedidoComponent\",\r\n  data() {\r\n    return {\r\n      listaPedidosRealizados: [],\r\n      listaStatusPedido: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarPedidos() {\r\n      const response = await fetch(`${this.$apiUrl}/pedidos`);\r\n      const dados = await response.json();\r\n      console.log(dados);\r\n      this.listaPedidosRealizados = dados;\r\n    },\r\n    async consultarStatusPedido() {\r\n      const response = await fetch(`${this.$apiUrl}/status_pedido`);\r\n      this.listaStatusPedido = await response.json();\r\n    },\r\n    async deletarPedido(id) {\r\n        const response = await fetch(`${this.$apiUrl}/pedidos/${id}`, {\r\n            method: \"DELETE\",\r\n        });\r\n    },\r\n       async atualizarStatuspedido(event, idPedido) {\r\n        const idStatusAtualizado = event.target.value;\r\n        const atualizarJson = JSON.stringify({ statusId: idStatusAtualizado });\r\n\r\n        await fetch(`http://localhost/pedidos/${idPedido}`, {\r\n         method: \"PATCH\",\r\n         headers: { \"Content-Type\": \"application/json\" },\r\n        body: atualizarJson,\r\n        });\r\n},\r\n  },\r\n  mounted() {\r\n    this.consultarPedidos();\r\n    this.consultarStatusPedido();\r\n  },\r\n};\r\n</script>\r\n<style scoped>\r\n#pedidos-tabela {\r\n  width: 100%;\r\n  margin: 0 auto;\r\n}\r\n\r\n#pedidos-tabela-cabecalho,\r\n#pedidos-tabela-linhas,\r\n.pedidos-tabela-linha {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n#pedidos-tabela-cabecalho {\r\n  font-weight: bold;\r\n  padding: 12px;\r\n  border-bottom: 2px solid #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho div,\r\n.pedidos-tabela-linha div {\r\n  width: 18%;\r\n}\r\n\r\n.pedidos-tabela-linha {\r\n  width: 100%;\r\n  padding: 12px;\r\n  border-bottom: 1px dotted #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho #ordem-id,\r\n.pedidos-tabela-linha #ordem-numero,\r\n.pedidos-tabela-linha #div-acoes,\r\n#pedidos-tabela-cabecalho #div-acoes {\r\n  width: 5%;\r\n}\r\n</style>\r\n"],"mappings":"AA6DA,eAAe;EACbA,IAAI,EAAE,sBAAsB;EAC5BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,sBAAsB,EAAE,EAAE;MAC1BC,iBAAiB,EAAE;IACrB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,gBAAgBA,CAAA,EAAG;MACvB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,C