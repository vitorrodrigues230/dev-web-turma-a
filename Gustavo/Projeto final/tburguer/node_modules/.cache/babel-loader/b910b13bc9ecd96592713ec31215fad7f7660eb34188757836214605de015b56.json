{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontoCarne: []\n    };\n  },\n  methods: {\n    async getTipoPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaPontoCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaComplemento = dados.listaComplemento;\n      this.listaBebidas = dados.bebidas;\n    }\n  },\n  mounted() {\n    this.getTipoPontos();\n    this.getOpcionais();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontoCarne","methods","getTipoPontos","response","fetch","dados","json","getOpcionais","listaComplemento","listaBebidas","bebidas","mounted"],"sources":["C:\\Users\\gusta\\OneDrive\\Documentos\\GGITHUBB\\dev-web-turma-a\\Gustavo\\Projeto final\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\">\r\n            <div>\r\n                <p id=\"nome-hamburguer-content\">\r\n                    {{ burguer && burguer.nome ? burguer.nome : \"-\" }}\r\n                </p>\r\n                <img id=\"foto-content\" :src=\"burguer && burguer.foto ? burguer.foto : ''\"\r\n                />\r\n            </div>\r\n            <div class=\"inputs\" id=\"form-pedido\">\r\n                <label>Nome</label>\r\n                <input type=\"text\" \r\n                id=\"nome-client\" \r\n                name=\"nome-cliente\" \r\n                placeholder=\"Digite seu Nome\"\r\n                />\r\n            </div>\r\n            <div class=\"inputs\">\r\n             <label>Ponto da carne</label>\r\n             <select name=\"ponto da carne\" id=\"ponto-carne\">\r\n             <option value=\"Selecione o ponto\"></option>\r\n             <option\r\n              v-for=\"pontoCarne in listaPontoCarne\"\r\n              :key=\"pontoCarne.id\"\r\n              value=\"1\">\r\n\r\n               {{ pontCarne.descricao }}\r\n             </option>\r\n            </select>\r\n            </div>\r\n            <div class=\"inputs\">\r\n                <label id=\"opcionais-titulo\">Selecione os opcionais</label>\r\n                <label id=\"opcionais-sibtitulos\">Selecione os complementos</label>\r\n\r\n              <div class=\"checkbox-container\"\r\n               v-for=\"complemento in listaComplementos\"\r\n               :key=\"complemento.id\">\r\n\r\n    \r\n                <input\r\n                 type=\"checkbox\" \r\n                 name=\"complemento.nome\"\r\n                />\r\n                <span>{{ complemento.nome }}</span>\r\n              </div>\r\n\r\n              <label>Adicione uma bebida </label>\r\n\r\n              <div id=\"checkbox-container\">\r\n                 <input type=\"checkbox\" name=\"bebida\" />\r\n                <span>Coca</span>\r\n              </div>\r\n              <div class=\"inputs\">\r\n                <input type=\"submit\" class=\"submit-bnt\" value=\"Confirmar pedido\">\r\n              </div>\r\n            </div>\r\n        </form>\r\n    </div>\r\n</template>\r\n<script>\r\nexport default {\r\n    name: \"PedidoComponent\",\r\n    props: {\r\n        burguer: null,        \r\n    },\r\n    data() {\r\n        return{\r\n            listaPontoCarne : [],\r\n        };\r\n    },\r\n    methods: {\r\n        async getTipoPontos() {\r\n            const response = await fetch(\"http://localhost:3000/tipos_pontos\")\r\n            const dados = await response.json();\r\n            this.listaPontoCarne = dados;\r\n        },\r\n        async getOpcionais() {\r\n            const response = await fetch(\"http://localhost:3000/tipos_pontos\")\r\n            const dados = await response.json();\r\n            this.listaComplemento = dados.listaComplemento\r\n            this.listaBebidas = dados.bebidas\r\n        }\r\n    },\r\n    mounted() {\r\n        this.getTipoPontos();\r\n        this.getOpcionais();\r\n    }\r\n};\r\n</script>\r\n<style scoped></style>"],"mappings":"AA6DA,eAAe;EACXA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;EACDC,IAAIA,CAAA,EAAG;IACH,OAAM;MACFC,eAAc,EAAI;IACtB,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,aAAaA,CAAA,EAAG;MAClB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,oCAAoC;MACjE,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACN,eAAc,GAAIK,KAAK;IAChC,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACjB,MAAMJ,QAAO,GAAI,MAAMC,KAAK,CAAC,oCAAoC;MACjE,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACE,gBAAe,GAAIH,KAAK,CAACG,gBAAe;MAC7C,IAAI,CAACC,YAAW,GAAIJ,KAAK,CAACK,OAAM;IACpC;EACJ,CAAC;EACDC,OAAOA,CAAA,EAAG;IACN,IAAI,CAACT,aAAa,CAAC,CAAC;IACpB,IAAI,CAACK,YAAY,CAAC,CAAC;EACvB;AACJ,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}