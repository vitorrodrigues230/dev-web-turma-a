{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontoCarne: []\n    };\n  },\n  methods: {\n    async getTipoPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaPontoCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n    }\n  },\n  mounted() {\n    this.getTipoPontos();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontoCarne","methods","getTipoPontos","response","fetch","dados","json","getOpcionais","mounted"],"sources":["C:\\Users\\lucas.palacio\\Desktop\\Github\\dev-web-turma-a\\Lucas Palacio\\Projeto Final\\tburguer\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\" >\r\n            <div >\r\n                <p id=\"nome-hamburguer-content\">\r\n                    {{burguer && burguer.nome ? burguer.nome : \"-\" }}\r\n\r\n                </p>\r\n                <img \r\n                id=\"foto-content\"\r\n                :src=\"burguer && burguer.foto? burguer.foto : '' \" >\r\n            </div>\r\n            <div class=\"inputs\" id=\"form-pedido\">\r\n                <label>nome</label>\r\n                <input \r\n                type=\"text\" \r\n                id=\"nome-cliente\" \r\n                name=\"nome-cliente\"\r\n                placeholder=\"Digite seu Nome\">\r\n            </div>\r\n            <div class=\"inputs\">\r\n                <label >Ponto da carne</label>\r\n                <select name=\"ponto-carne\" id=\"ponto-carne\">\r\n                    <option value=\"\">Selecione o ponto </option>\r\n                    <option \r\n                    v-for=\"pontoCarne in listaPontoCarne\" \r\n                    :key=\"pontoCarne.id\" \r\n                    value=\"1\"\r\n                    >\r\n                    {{ pontoCarne.descricao }} \r\n                </option>\r\n                </select>\r\n            </div>\r\n            <div class=\"inputs\">\r\n                <label id=\"opcionais-titulo\">Selecione os opcionais</label>\r\n                <label id=\"opcionais-subtitulo\"> Selecione os complementos</label>\r\n\r\n                <div class=\"checkbox-container\">\r\n                    <input type=\"checkbox\" name=\"complemento\" />\r\n                    <span >Batata</span>\r\n                </div>\r\n\r\n                <label > Adicione uma bebida</label>\r\n\r\n                <div id=\"checkbox-container\">\r\n                    <input type=\"checkbox\" name=\"bebida\" />\r\n                    <span>Coca</span>\r\n                </div>\r\n                <div class=\"inputs\">\r\n                    <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\">\r\n\r\n                </div>\r\n            </div>\r\n        \r\n        </form>\r\n\r\n\r\n\r\n    </div>    \r\n</template>\r\n\r\n<script>\r\nexport default{\r\n    name:\"PedidoComponent\",\r\n    props: {\r\n        burguer: null,\r\n    },\r\n    data(){\r\n        return{\r\n            listaPontoCarne : [],\r\n        };\r\n    },\r\n    methods: {\r\n        async getTipoPontos(){\r\n            const response =  await fetch(\"http://localhost:3000/tipos_pontos\")\r\n            const dados = await response.json();\r\n            this.listaPontoCarne = dados;\r\n        },\r\n        async getOpcionais(){\r\n            const response = await fetch(\"http://localhost:3000/opcionais\")\r\n            const dados = await response.json();\r\n        },\r\n    },\r\n\r\n    mounted(){\r\n        this.getTipoPontos();\r\n    },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n\r\n\r\n</style>"],"mappings":"AA8DA,eAAc;EACVA,IAAI,EAAC,iBAAiB;EACtBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;E