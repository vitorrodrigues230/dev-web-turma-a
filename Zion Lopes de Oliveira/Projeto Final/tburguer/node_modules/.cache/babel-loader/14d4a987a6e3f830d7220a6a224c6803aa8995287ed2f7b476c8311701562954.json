{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontoCarne: [],\n      listaBebidas: [],\n      listaComplementos: []\n    };\n  },\n  methods: {\n    async getTipoPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaPontoCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n      this.listaComplementos = dados.complemento;\n      this.listaBebidas = dados.bedidas;\n    }\n  },\n  mounted() {\n    this.getTipoPontos();\n    this.getOpcionais();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontoCarne","listaBebidas","listaComplementos","methods","getTipoPontos","response","fetch","dados","json","getOpcionais","complemento","bedidas","mounted"],"sources":["C:\\Users\\lucas.palacio\\Desktop\\Github\\dev-web-turma-a\\Lucas Palacio\\Projeto Final\\tburguer\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\" >\r\n            <div >\r\n                <p id=\"nome-hamburguer-content\">\r\n                    {{burguer && burguer.nome ? burguer.nome : \"-\" }}\r\n\r\n                </p>\r\n                <img \r\n                id=\"foto-content\"\r\n                :src=\"burguer && burguer.foto? burguer.foto : '' \" >\r\n            </div>\r\n            <div class=\"inputs\" id=\"form-pedido\">\r\n                <label>nome</label>\r\n                <input \r\n                type=\"text\" \r\n                id=\"nome-cliente\" \r\n                name=\"nome-cliente\"\r\n                placeholder=\"Digite seu Nome\">\r\n            </div>\r\n            <div class=\"inputs\">\r\n                <label >Ponto da carne</label>\r\n                <select name=\"ponto-carne\" id=\"ponto-carne\">\r\n                    <option value=\"\">Selecione o ponto </option>\r\n                    <option \r\n                    v-for=\"pontoCarne in listaPontoCarne\" \r\n                    :key=\"pontoCarne.id\" \r\n                    value=\"1\"\r\n                    >\r\n                    {{ pontoCarne.descricao }} \r\n                </option>\r\n                </select>\r\n            </div>\r\n            <div class=\"inputs\">\r\n                <label id=\"opcionais-titulo\">Selecione os opcionais</label>\r\n                <label id=\"opcionais-subtitulo\"> Selecione os complementos</label>\r\n\r\n                <div class=\"checkbox-container\" \r\n                v-for=\"complemento in listaComplementos\"\r\n                :key=\"complemento.id\"\r\n                >\r\n                    <input type=\"checkbox\" \r\n                    :name=\"complemento.nome\" \r\n                    :value=\"complemento\" \r\n                    />\r\n                    <span >{{ complemento.nome }}</span>\r\n                </div>\r\n\r\n                <label > Adicione uma bebida</label>\r\n\r\n                <div id=\"checkbox-container\">\r\n                    <input type=\"checkbox\" name=\"bebida\" />\r\n                    <span>Coca</span>\r\n                </div>\r\n                <div class=\"inputs\">\r\n                    <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\">\r\n\r\n                </div>\r\n            </div>\r\n        \r\n        </form>\r\n\r\n\r\n\r\n    </div>    \r\n</template>\r\n\r\n<script>\r\nexport default{\r\n    name:\"PedidoComponent\",\r\n    props: {\r\n        burguer: null,\r\n    },\r\n    data(){\r\n        return{\r\n            listaPontoCarne : [],\r\n            listaBebidas: [],\r\n            listaComplementos: [],\r\n        };\r\n    },\r\n    methods: {\r\n        async getTipoPontos(){\r\n            const response =  await fetch(\"http://localhost:3000/tipos_pontos\")\r\n            const dados = await response.json();\r\n            this.listaPontoCarne = dados;\r\n        },\r\n        async getOpcionais(){\r\n            const response = await fetch(\"http://localhost:3000/opcionais\")\r\n            const dados = await response.json();\r\n            this.listaComplementos = dados.complemento;\r\n            this.listaBebidas = dados.bedidas;\r\n        },\r\n    },\r\n\r\n    mounted(){\r\n        this.getTipoPontos();\r\n        this.getOpcionais();\r\n    },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n\r\n\r\n</style>"],"mappings":"AAoEA,eAAc;EACVA,IAAI,EAAC,iBAAiB;EACtBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;EACDC,IAAIA,CAAA,EAAE;IACF,OAAM;MACFC,eAAc,EAAI,EAAE;MACpBC,YAAY,EAAE,EAAE;MAChBC,iBAAiB,EAAE;IACvB,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,aAAaA,CAAA,EAAE;MACjB,MAAMC,QAAO,GAAK,MAAMC,KAAK,CAAC,oCAAoC;MAClE,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACR,eAAc,GAAIO,KAAK;IAChC,CAAC;IACD,MAAME,YAAYA,CAAA,EAAE;MAChB,MAAMJ,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiC;MAC9D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACN,iBAAgB,GAAIK,KAAK,CAACG,WAAW;MAC1C,IAAI,CAACT,YAAW,GAAIM,KAAK,CAACI,OAAO;IACrC;EACJ,CAAC;EAEDC,OAAOA,CAAA,EAAE;IACL,IAAI,CAACR,aAAa,CAAC,CAAC;IACpB,IAAI,CAACK,YAAY,CAAC,CAAC;EACvB;AACJ,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}