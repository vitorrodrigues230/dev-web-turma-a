{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontoCarne: [],\n      listaBebidas: [],\n      listaComplementos: [],\n      nomeCliente: \"\",\n      pontoCarneSelecionado: \"\",\n      listaComplementosSelecionados: [],\n      listaBebidasSelecionadas: []\n    };\n  },\n  methods: {\n    async getTipoPontos() {\n      const response = await fetch(`${this.$apiUrl}/tipos_pontos`);\n      const dados = await response.json();\n      this.listaPontoCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(`${this.$apiUrl}/opcionais`);\n      const dados = await response.json();\n      this.listaComplementos = dados.complemento;\n      this.listaBebidas = dados.bebidas;\n    },\n    async criarPedido(e) {\n      e.preventDefault();\n      const dadosPedido = {\n        nome: this.nomeCliente,\n        ponto: this.pontoCarneSelecionado,\n        bebidas: Array.from(this.listaBebidasSelecionadas),\n        complemento: Array.from(this.listaComplementosSelecionados),\n        burguer: this.burguer,\n        statusId: 5\n      };\n      console.log(dadosPedido);\n      const dadosJson = JSON.stringify(dadosPedido);\n      const req = await fetch(`${this.$apiUrl}/pedidos`, {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\"\n        },\n        body: dadosJson\n      });\n    }\n  },\n  mounted() {\n    this.getTipoPontos();\n    this.getOpcionais();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontoCarne","listaBebidas","listaComplementos","nomeCliente","pontoCarneSelecionado","listaComplementosSelecionados","listaBebidasSelecionadas","methods","getTipoPontos","response","fetch","$apiUrl","dados","json","getOpcionais","complemento","bebidas","criarPedido","e","preventDefault","dadosPedido","nome","ponto","Array","from","statusId","console","log","dadosJson","JSON","stringify","req","method","headers","body","mounted"],"sources":["C:\\Users\\zion.lopes\\Desktop\\Github\\dev-web-turma-a\\Zion Lopes de Oliveira\\Projeto Final\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <form id=\"pedido-form\" @submit=\"criarPedido($event)\">\r\n      <div>\r\n        <p id=\"nome-hamburguer-content\">\r\n          {{ burguer && burguer.nome ? burguer.nome : \"-\" }}\r\n        </p>\r\n        <img\r\n          id=\"foto-content\"\r\n          :src=\"burguer && burguer.foto ? burguer.foto : ''\"\r\n        />\r\n      </div>\r\n      <div class=\"inputs\">\r\n        <label for=\"nome-cliente\">Nome</label>\r\n        <input\r\n          type=\"text\"\r\n          v-model=\"nomeCliente\"\r\n          id=\"nome-cliente\"\r\n          name=\"nome-cliente\"\r\n          placeholder=\"Digite seu Nome\"\r\n        />\r\n      </div>\r\n      <div class=\"inputs\">\r\n        <label>Ponto da carne</label>\r\n        <select \r\n         name=\"ponto-carne\" \r\n         id=\"ponto-carne\" \r\n         v-model=\"pontoCarneSelecionado\"\r\n        >\r\n          <option value=\"\" selected>Selecione o ponto</option>\r\n          <option\r\n            v-for=\"pontoCarne in listaPontoCarne\"\r\n            :key=\"pontoCarne.id\"\r\n            :value=\"pontoCarne\"\r\n          >\r\n            {{ pontoCarne.descricao }}\r\n          </option>\r\n        </select>\r\n      </div>\r\n      <div class=\"inputs\">\r\n        <label id=\"opcionais-titulo\"> Selecione os opcionais</label>\r\n        <label id=\"opcionais-subtitulo\"> Selecione os complementos</label>\r\n\r\n        <div\r\n          class=\"checkbox-container\"\r\n          v-for=\"complemento in listaComplementos\"\r\n          :key=\"complemento.id\"\r\n        >\r\n          <input\r\n            type=\"checkbox\"\r\n            :name=\"complemento.nome\"\r\n            :value=\"complemento\"\r\n            v-model=\"listaComplementosSelecionados\"\r\n          />\r\n          <span>{{ complemento.nome }}</span>\r\n        </div>\r\n\r\n        <label> Adicione uma bebida</label>\r\n\r\n        <div\r\n          class=\"checkbox-container\"\r\n          id=\"checkbox-container\"\r\n          v-for=\"bebida in listaBebidas\"\r\n          :key=\"bebida.id\"\r\n        >\r\n          <input \r\n          type=\"checkbox\" \r\n          :name=\"bebida.nome\" \r\n          :value=\"bebida\" \r\n          v-model=\"listaBebidasSelecionadas\" \r\n        />\r\n          <span>{{ bebida.nome }}</span>\r\n        </div>\r\n        <div class=\"inputs\">\r\n          <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\" />\r\n        </div>\r\n      </div>\r\n    </form>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"PedidoComponent\",\r\n  props: {\r\n    burguer: null,\r\n  },\r\n  data() {\r\n    return {\r\n      listaPontoCarne: [],\r\n      listaBebidas: [],\r\n      listaComplementos: [],\r\n      nomeCliente: \"\",\r\n      pontoCarneSelecionado: \"\",\r\n      listaComplementosSelecionados: [],\r\n      listaBebidasSelecionadas: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async getTipoPontos() {\r\n      const response = await fetch(`${this.$apiUrl}/tipos_pontos`);\r\n      const dados = await response.json();\r\n      this.listaPontoCarne = dados;\r\n    },\r\n    async getOpcionais() {\r\n      const response = await fetch(`${this.$apiUrl}/opcionais`);\r\n      const dados = await response.json();\r\n      this.listaComplementos = dados.complemento;\r\n      this.listaBebidas = dados.bebidas;\r\n    },\r\n    async criarPedido(e){\r\n        e.preventDefault();\r\n      \r\n      const dadosPedido = {\r\n        nome: this.nomeCliente,\r\n        ponto: this.pontoCarneSelecionado,\r\n        bebidas: Array.from(this.listaBebidasSelecionadas),\r\n        complemento: Array.from(this.listaComplementosSelecionados),\r\n        burguer: this.burguer,\r\n        statusId: 5,\r\n      };\r\n\r\n      console.log(dadosPedido);\r\n\r\n      const dadosJson = JSON.stringify(dadosPedido);\r\n\r\n      const req = await fetch(`${this.$apiUrl}/pedidos`, {\r\n        method: \"POST\",\r\n        headers: {\"Content-Type\" : \"application/json\"},\r\n        body: dadosJson,\r\n      });\r\n    },\r\n  },\r\n  mounted() {\r\n    this.getTipoPontos();\r\n    this.getOpcionais();\r\n  },\r\n};\r\n</script>\r\n<style scoped>\r\n#foto-content {\r\n  margin-bottom: 16px;\r\n  border-radius: 16px;\r\n  position: relative;\r\n  z-index: -1;\r\n  justify-content: center;\r\n  width: 100%;\r\n  height: 180px;\r\n  object-fit: cover;\r\n}\r\n\r\n#nome-hamburguer-content {\r\n  font-size: 43px;\r\n  font-weight: bold;\r\n  text-align: start;\r\n  margin-bottom: -90px;\r\n  margin-left: 40px;\r\n  color: antiquewhite;\r\n  padding: 16px;\r\n}\r\n\r\n#form-pedido {\r\n  max-width: 750px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.inputs {\r\n  display: flex;\r\n  flex-direction: column;\r\n  margin-bottom: 16px;\r\n}\r\n\r\nlabel {\r\n  font-weight: bold;\r\n  margin-bottom: 16px;\r\n  color: #222;\r\n  padding: 5px 12px;\r\n  flex-direction: start;\r\n  display: flex;\r\n  border-left: 4px solid darkgoldenrod;\r\n}\r\n\r\ninput,\r\nselect {\r\n  padding: 12px;\r\n  width: 300px;\r\n  border: solid #222 1px;\r\n  border-radius: 8px;\r\n  height: 20px;\r\n  font-size: 12px;\r\n}\r\n\r\nselect {\r\n  height: 45px;\r\n}\r\n\r\n#opcionais-titulo {\r\n  width: 100%;\r\n}\r\n\r\n#opcionais-subtitulo {\r\n  display: flex;\r\n  align-items: flex-start;\r\n  align-content: center;\r\n  width: 100%;\r\n  margin-bottom: 12px;\r\n}\r\n\r\n.checkbox-container span {\r\n  margin-left: 6px;\r\n  font-weight: bold;\r\n}\r\n\r\n.checkbox-container span,\r\n.checkbox-container input {\r\n  width: auto;\r\n  height: 20px;\r\n}\r\n\r\n.submit-btn {\r\n  background-color: #222;\r\n  color: darkgoldenrod;\r\n  font-weight: bold;\r\n  border: none;\r\n  font-size: 18px;\r\n  border-radius: 12px;\r\n  padding: 16px;\r\n  margin: 0 auto;\r\n  cursor: pointer;\r\n  width: 100%;\r\n  height: auto;\r\n  transition: 0.5s;\r\n}\r\n\r\n.submit-btn:hover {\r\n  background-color: darkgoldenrod;\r\n  color: #222;\r\n}\r\n</style>"],"mappings":"AAiFA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACLC,OAAO,EAAE;EACX,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,eAAe,EAAE,EAAE;MACnBC,YAAY,EAAE,EAAE;MAChBC,iBAAiB,EAAE,EAAE;MACrBC,WAAW,EAAE,EAAE;MACfC,qBAAqB,EAAE,EAAE;MACzBC,6BAA6B,EAAE,EAAE;MACjCC,wBAAwB,EAAE;IAC5B,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,eAAe,CAAC;MAC5D,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;MACnC,IAAI,CAACb,eAAc,GAAIY,KAAK;IAC9B,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACnB,MAAML,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,YAAY,CAAC;MACzD,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;MACnC,IAAI,CAACX,iBAAgB,GAAIU,KAAK,CAACG,WAAW;MAC1C,IAAI,CAACd,YAAW,GAAIW,KAAK,CAACI,OAAO;IACnC,CAAC;IACD,MAAMC,WAAWA,CAACC,CAAC,EAAC;MAChBA,CAAC,CAACC,cAAc,CAAC,CAAC;MAEpB,MAAMC,WAAU,GAAI;QAClBC,IAAI,EAAE,IAAI,CAAClB,WAAW;QACtBmB,KAAK,EAAE,IAAI,CAAClB,qBAAqB;QACjCY,OAAO,EAAEO,KAAK,CAACC,IAAI,CAAC,IAAI,CAAClB,wBAAwB,CAAC;QAClDS,WAAW,EAAEQ,KAAK,CAACC,IAAI,CAAC,IAAI,CAACnB,6BAA6B,CAAC;QAC3DP,OAAO,EAAE,IAAI,CAACA,OAAO;QACrB2B,QAAQ,EAAE;MACZ,CAAC;MAEDC,OAAO,CAACC,GAAG,CAACP,WAAW,CAAC;MAExB,MAAMQ,SAAQ,GAAIC,IAAI,CAACC,SAAS,CAACV,WAAW,CAAC;MAE7C,MAAMW,GAAE,GAAI,MAAMrB,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,UAAU,EAAE;QACjDqB,MAAM,EAAE,MAAM;QACdC,OAAO,EAAE;UAAC,cAAa,EAAI;QAAkB,CAAC;QAC9CC,IAAI,EAAEN;MACR,CAAC,CAAC;IACJ;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAAC3B,aAAa,CAAC,CAAC;IACpB,IAAI,CAACM,YAAY,CAAC,CAAC;EACrB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}