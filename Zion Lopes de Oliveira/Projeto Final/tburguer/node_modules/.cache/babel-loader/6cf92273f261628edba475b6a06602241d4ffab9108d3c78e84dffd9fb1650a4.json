{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuHamburgues: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"http://localhost:3000/menu\");\n      const dados = await response.json();\n      this.listaMenuHamburgues = dados.burgues;\n      console.log(this.listaMenuHamburgues);\n    },\n    selecionarBurguer(burguerSelecionado) {\n      const param = JSON.stringify(burguerSelecionado);\n      const burguerJson = encodeURIComponent(param);\n      this.$router.push({\n        path: '/config',\n        query: {\n          burguer: burguerJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuHamburgues","methods","consultarMenu","response","fetch","dados","json","burgues","console","log","selecionarBurguer","burguerSelecionado","param","JSON","stringify","burguerJson","encodeURIComponent","$router","push","path","query","burguer","mounted"],"sources":["C:\\Users\\lucas.palacio\\Desktop\\Github\\dev-web-turma-a\\Lucas Palacio\\Projeto Final\\tburguer\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <h1>Menu</h1>\r\n    <div id=\"scroll-horizontal\">\r\n      <div\r\n        id=\"card-content\"\r\n        v-for=\"burguer in listaMenuHamburgues\"\r\n        :key=\"burguer.id\"\r\n      >\r\n        <div id=\"card-linha\">\r\n          <div class=\"foto-hamburguer\">\r\n            <img :src=\"burguer.foto\" alt=\"nome do burguer\" />\r\n            <div class=\"card-coluna\">\r\n              <p id=\"nome-content\">{{ burguer.nome }}</p>\r\n              <p id=\"preco-content\">R$ {{ burguer.valor }},00</p>\r\n              <p id=\"descricao-content\">{{ burguer.descricao }}</p>\r\n              <button @click=\"selecionarBurguer(burguer)\">Selecionar</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuHamburgues: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarMenu() {\r\n      const response = await fetch(\"http://localhost:3000/menu\");\r\n      const dados = await response.json();\r\n      this.listaMenuHamburgues = dados.burgues;\r\n      console.log(this.listaMenuHamburgues);\r\n    },\r\n    selecionarBurguer(burguerSelecionado){\r\n        const param = JSON.stringify(burguerSelecionado);\r\n        const burguerJson = encodeURIComponent(param);\r\n        this.$router.push({path: '/config', query: {burguer : burguerJson}});\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  },\r\n};\r\n</script>\r\n<style scoped>\r\n#card-content {\r\n  display: inline-block;\r\n  width: 280px;\r\n  min-height: 500px;\r\n  margin: 20px;\r\n  border: 1px solid #ddd;\r\n  border-radius: 15px;\r\n  box-shadow: 0 4px 8px #444;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n#scroll-horizontal {\r\n  flex: 1;\r\n  overflow-x: auto;\r\n  white-space: nowrap;\r\n  width: 700px;\r\n  margin: 0 auto;\r\n  box-shadow: inset -10px 0px 15px -15px grey;\r\n}\r\n\r\n.foto-hamburguer img {\r\n  width: 100%;\r\n  object-fit: cover;\r\n  max-height: 200px;\r\n  border-radius: 10px 0 0;\r\n}\r\n\r\n#nome-content {\r\n  font-size: 25px;\r\n  font-weight: bold;\r\n  text-align: center;\r\n  width: 100%;\r\n  margin: 12px;\r\n}\r\n\r\n#preco-content {\r\n  font-size: 35px;\r\n  text-align: center;\r\n  font-weight: bold;\r\n  color: green;\r\n  margin: 16px;\r\n}\r\n\r\n#descricao-content {\r\n  font-size: 16px;\r\n  text-align: left;\r\n  color: gray;\r\n  margin: 16px;\r\n  white-space: pre-line;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 6;\r\n  -webkit-box-orient: vertical;\r\n}\r\n\r\n.card-coluna button {\r\n  margin-top: auto;\r\n  padding: 10px;\r\n  background-color: rgb(53, 108, 121);\r\n  color: #fff;\r\n  font-weight: bold;\r\n  border-radius: 8px;\r\n  border: none;\r\n  font-size: 14px;\r\n  width: 80%;\r\n  margin: 20px;\r\n  cursor: pointer;\r\n  transition: 0.5s;\r\n}\r\n\r\n.card-coluna button:hover {\r\n  background-color: transparent;\r\n  color: darkslategray;\r\n  border-radius: 8px;\r\n  border: solid 1px rgb(53, 108, 121);\r\n}\r\n</style>"],"mappings":";AAyBA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,mBAAmB,EAAE;IACvB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,4BAA4B,CAAC;MAC1D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACN,mBAAkB,GAAIK,KAAK,CAACE,OAAO;MACxCC,OAAO,CAACC,GAAG,CAAC,IAAI,CAACT,mBAAmB,CAAC;IACvC,CAAC;IACDU,iBAAiBA,CAACC,kBAAkB,EAAC;MACjC,MAAMC,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACH,kBAAkB,CAAC;MAChD,MAAMI,WAAU,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC7C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAACC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE;UAACC,OAAM,EAAIN;QAAW;MAAC,CAAC,CAAC;IACxE;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACpB,aAAa,CAAC,CAAC;EACtB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}