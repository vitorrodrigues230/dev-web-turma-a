{"ast":null,"code":"export default {\n  name: \"ListaPedidoComponent\",\n  data() {\n    return {\n      listaPedidosRealizados: [],\n      listaStatusPedidos\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(\"http://localhost:3000/pedidos\");\n      const dados = await response.json();\n      console.log(dados);\n      this.listaPedidosRealizados = dados;\n    },\n    async consultarStatusPedido() {\n      const response = await fetch(\"http://localhost:3000/status_pedido\");\n      this.listaStatusPedidos = await response.json();\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n    this.consultarStatusPedido();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidosRealizados","listaStatusPedidos","methods","consultarPedidos","response","fetch","dados","json","console","log","consultarStatusPedido","mounted"],"sources":["C:\\Users\\lucas.palacio\\Desktop\\Github\\dev-web-turma-a\\Lucas Palacio\\Projeto Final\\tburguer\\tburguer\\src\\components\\ListaPedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div id=\"pedidos-tabela\">\r\n      <div>\r\n        <div id=\"pedidos-tabela-cabecalho\">\r\n          <div id=\"ordem-id\">#ID</div>\r\n          <div>Nome</div>\r\n          <div>Hamburguer</div>\r\n          <div>Ponto</div>\r\n          <div>Opcionais</div>\r\n          <div>Status</div>\r\n          <div id=\"div-acoes\">Ações</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div\r\n      class=\"pedidos-tabela-linha\"\r\n      v-for=\"pedido in listaPedidosRealizados\"\r\n      :key=\"pedido.id\"\r\n    >\r\n      <div id=\"ordem-numero\">{{ pedido.id }}</div>\r\n      <div>{{ pedido.nome }}</div>\r\n      <div>{{ pedido.burguer.nome }}</div>\r\n      <div>{{ pedido.ponto.descricao }}</div>\r\n      <div>\r\n\r\n        <ul>\r\n            <li v-for=\"(complemento, index) in pedido.complemento\"\r\n            :key=\"index\">{{ complemento.nome }}</li>\r\n        </ul>\r\n        <div class=\"divider\"></div>\r\n        <ul>\r\n            <li v-for=\"(complemento, index) in pedido.bebida\"\r\n            :key=\"index\">{{ bebida.nome }}</li>\r\n        </ul>\r\n\r\n\r\n      </div>\r\n      <select name=\"status\">\r\n        <option value=\"\">Selecione</option>\r\n        <option v-for=\"status in listaStatusPedidos\"\r\n        :key=\"status.id\"\r\n        :value=\"status.id\"\r\n        :selected=\"status.id == pedido.statusId\">\r\n        {{ status.descricao }}\r\n        </option>\r\n      </select>\r\n      \r\n      <div id=\"div-acoes\">\r\n        <img src=\"/img/icone_lixeira.png\" width=\"35px\" height=\"35px\" />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"ListaPedidoComponent\",\r\n  data() {\r\n    return {\r\n      listaPedidosRealizados: [],\r\n      listaStatusPedidos\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarPedidos() {\r\n      const response = await fetch(\"http://localhost:3000/pedidos\");\r\n      const dados = await response.json();\r\n      console.log(dados);\r\n      this.listaPedidosRealizados = dados;\r\n    },\r\n    async consultarStatusPedido(){\r\n        const response = await fetch(\"http://localhost:3000/status_pedido\");\r\n        this.listaStatusPedidos = await response.json();\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarPedidos();\r\n    this.consultarStatusPedido();\r\n  },\r\n};\r\n</script>\r\n<style scoped>\r\n#pedidos-tabela {\r\n  width: 100%;\r\n  margin: 0 auto;\r\n}\r\n\r\n#pedidos-tabela-cabecalho,\r\n#pedidos-tabela-linhas,\r\n.pedidos-tabela-linha {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n#pedidos-tabela-cabecalho {\r\n  font-weight: bold;\r\n  padding: 12px;\r\n  border-bottom: 2px solid #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho div,\r\n.pedidos-tabela-linha div {\r\n  width: 18%;\r\n}\r\n\r\n.pedidos-tabela-linha {\r\n  width: 100%;\r\n  padding: 12px;\r\n  border-bottom: 1px dotted #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho #ordem-id,\r\n.pedidos-tabela-linha #ordem-numero,\r\n.pedidos-tabela-linha #div-acoes,\r\n#pedidos-tabela-cabecalho #div-acoes {\r\n  width: 5%;\r\n}\r\n</style>"],"mappings":"AAuDA,eAAe;EACbA,IAAI,EAAE,sBAAsB;EAC5BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,sBAAsB,EAAE,EAAE;MAC1BC;IACF,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,gBAAgBA,CAAA,EAAG;MACvB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,+BAA+B,CAAC;MAC7D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnCC,OAAO,CAACC,GAAG,CAACH,KAAK,CAAC;MAClB,IAAI,CAACN,sBAAqB,GAAIM,KAAK;IACrC,CAAC;IACD,MAAMI,qBAAqBA,CAAA,EAAE;MACzB,MAAMN,QAAO,GAAI,MAAMC,KAAK,CAAC,qCAAqC,CAAC;MACnE,IAAI,CAACJ,kBAAiB,GAAI,MAAMG,QAAQ,CAACG,IAAI,CAAC,CAAC;IACnD;EACF,CAAC;EACDI,OAAOA,CAAA,EAAG;IACR,IAAI,CAACR,gBAAgB,CAAC,CAAC;IACvB,IAAI,CAACO,qBAAqB,CAAC,CAAC;EAC9B;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}